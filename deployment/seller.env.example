# ─────────────────────────────────────────────────────────────────────
# Base Network Pulse — SELLER-ONLY storefront environment
# ─────────────────────────────────────────────────────────────────────
# Copy to `seller.env`, fill in the values, and deploy. This template
# carries EVERYTHING a public storefront needs to publish the Pulse
# product, serve the HTTP 402 challenge, and settle sales to your
# receive address via the Coinbase CDP facilitator.
#
# ⚠️  DO NOT set EVM_PRIVATE_KEY here — a seller storefront must not hold
#     a spend key. Sales settle to X402_PAY_TO_ADDRESS via the CDP
#     facilitator. EVM_PRIVATE_KEY is a BUYER-ONLY secret; a public
#     seller deployment that carries it is exposing a funded wallet.
# ─────────────────────────────────────────────────────────────────────

# Your on-chain receive address — all sales settle here (Base mainnet).
X402_PAY_TO_ADDRESS=

# Coinbase CDP API key (Ed25519). Required to verify + settle x402 on
# Base mainnet; the free x402.org facilitator only settles Base Sepolia.
# Rotate any key that has ever been shared in plaintext.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Route Base mainnet settlement through the CDP facilitator.
CDP_NETWORKS=eip155:8453

# Network the storefront lists the Pulse product on (Base mainnet).
SWARM_SELL_NETWORK=eip155:8453

# Enable POST actions (publishing a listing). Read-only if false.
DASHBOARD_ACTIONS=true

# Public origin buyers reach the storefront at — used to build the
# purchase URL returned by POST /pulse/publish. Set to your tunnel/VPS host.
PUBLIC_BASE_URL=https://your-public-host

# List price for a synthesized Base Network Pulse report.
PULSE_PRICE=$8.00
