# x402 MCP Server Configuration

# Server
HOST=0.0.0.0
PORT=8402
UPGRADE_URL=https://forge.example.com/upgrade
PUBLIC_BASE_URL=http://localhost:8402

# Commerce (MCP tool quota — separate from on-chain x402 payments)
FREE_TIER_MONTHLY_QUOTA=500
FREE_TIER_RATE_LIMIT_PER_MIN=10

# Redis migration (optional — in-memory by default)
# REDIS_URL=redis://localhost:6379/0

# x402 Buyer (optional — required for pay_and_fetch)
EVM_PRIVATE_KEY=
SVM_PRIVATE_KEY=

# x402 Seller (optional — required for verify_payment_payload / build_seller_requirements)
X402_PAY_TO_ADDRESS=
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_DEFAULT_NETWORK=eip155:84532
X402_DEFAULT_PRICE=$0.01

# CDP facilitator (production — future/alternate x402 rail)
# X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

# Stripe fiat payment rail (primary for card/bank checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Mission-control dashboard (default read-only)
DASHBOARD_ACTIONS=false